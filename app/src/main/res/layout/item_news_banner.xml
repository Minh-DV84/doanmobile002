<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Ảnh banner lớn -->
        <ImageView
            android:id="@+id/imgBanner"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scaleType="centerCrop" />

        <!-- Gradient overlay phía dưới ảnh -->
        <View
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/gradient_banner_overlay" />

        <!-- Nhãn nguồn (badge) -->
        <TextView
            android:id="@+id/tvBannerCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="14dp"
            android:background="@drawable/bg_category_badge"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:maxWidth="140dp" />

        <!-- Tiêu đề bài viết -->
        <TextView
            android:id="@+id/tvBannerTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@+id/tvBannerMeta"
            android:layout_margin="14dp"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:maxLines="3"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.2" />

        <!-- Meta: thời gian -->
        <TextView
            android:id="@+id/tvBannerMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="14dp"
            android:drawableStart="@drawable/ic_time"
            android:drawablePadding="4dp"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:gravity="center_vertical" />

    </RelativeLayout>

</androidx.cardview.widget.CardView>