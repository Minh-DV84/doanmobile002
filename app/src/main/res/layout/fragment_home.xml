<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/homeSwipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Sử dụng CoordinatorLayout làm gốc bên trong để quản lý hành vi cuộn mượt mà hơn -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F6FA">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:elevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_scrollFlags="scroll|enterAlways">

                <!-- ══════════════════════════════════════════════════════════════ -->
                <!-- Search bar & Hashtags                                          -->
                <!-- ══════════════════════════════════════════════════════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:elevation="2dp"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="8dp">

                    <EditText
                        android:id="@+id/homeEtSearch"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_search"
                        android:drawableStart="@drawable/ic_search"
                        android:drawablePadding="10dp"
                        android:hint="Tìm kiếm tin tức..."
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:singleLine="true"
                        android:textColor="#1A1A2E"
                        android:textColorHint="#9E9E9E"
                        android:textSize="14sp" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:scrollbars="none"
                        android:clipToPadding="false">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView android:id="@+id/chipThoiSu" android:layout_width="wrap_content" android:layout_height="32dp" android:layout_marginEnd="8dp" android:background="@drawable/bg_chip" android:gravity="center" android:paddingStart="14dp" android:paddingEnd="14dp" android:text="#thời sự" android:textColor="#1877F2" android:textSize="12sp" android:textStyle="bold" />
                            <TextView android:id="@+id/chipTheThao" android:layout_width="wrap_content" android:layout_height="32dp" android:layout_marginEnd="8dp" android:background="@drawable/bg_chip" android:gravity="center" android:paddingStart="14dp" android:paddingEnd="14dp" android:text="#thể thao" android:textColor="#1877F2" android:textSize="12sp" android:textStyle="bold" />
                            <TextView android:id="@+id/chipKinhTe" android:layout_width="wrap_content" android:layout_height="32dp" android:layout_marginEnd="8dp" android:background="@drawable/bg_chip" android:gravity="center" android:paddingStart="14dp" android:paddingEnd="14dp" android:text="#kinh tế" android:textColor="#1877F2" android:textSize="12sp" android:textStyle="bold" />
                            <TextView android:id="@+id/chipSucKhoe" android:layout_width="wrap_content" android:layout_height="32dp" android:layout_marginEnd="8dp" android:background="@drawable/bg_chip" android:gravity="center" android:paddingStart="14dp" android:paddingEnd="14dp" android:text="#sức khỏe" android:textColor="#1877F2" android:textSize="12sp" android:textStyle="bold" />
                            <TextView android:id="@+id/chipKhoaHoc" android:layout_width="wrap_content" android:layout_height="32dp" android:layout_marginEnd="8dp" android:background="@drawable/bg_chip" android:gravity="center" android:paddingStart="14dp" android:paddingEnd="14dp" android:text="#khoa học" android:textColor="#1877F2" android:textSize="12sp" android:textStyle="bold" />
                            <TextView android:id="@+id/chipTheGioi" android:layout_width="wrap_content" android:layout_height="32dp" android:layout_marginEnd="8dp" android:background="@drawable/bg_chip" android:gravity="center" android:paddingStart="14dp" android:paddingEnd="14dp" android:text="#thế giới" android:textColor="#1877F2" android:textSize="12sp" android:textStyle="bold" />
                            <TextView android:id="@+id/chipGiaiTri" android:layout_width="wrap_content" android:layout_height="32dp" android:layout_marginEnd="4dp" android:background="@drawable/bg_chip" android:gravity="center" android:paddingStart="14dp" android:paddingEnd="14dp" android:text="#giải trí" android:textColor="#1877F2" android:textSize="12sp" android:textStyle="bold" />
                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>

                <!-- Offline banner -->
                <LinearLayout
                    android:id="@+id/offlineBanner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FF6B35"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="10dp"
                    android:visibility="gone">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_notification" app:tint="#FFFFFF" />
                    <TextView android:id="@+id/tvOfflineMsg" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Bạn đang ở chế độ ngoại tuyến — hiển thị tin đã cache" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- ══════════════════════════════════════════════════════════════ -->
                <!-- 4 Widget Cards Row                                             -->
                <!-- ══════════════════════════════════════════════════════════════ -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingTop="12dp"
                    android:paddingBottom="4dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:clipToPadding="false">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Card 1: Thứ / Ngày -->
                        <androidx.cardview.widget.CardView android:layout_width="110dp" android:layout_height="100dp" android:layout_marginEnd="10dp" app:cardCornerRadius="16dp" app:cardElevation="3dp" app:cardBackgroundColor="#1877F2"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical" android:padding="10dp"><TextView android:id="@+id/tvDayOfWeek" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thứ hai" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" /><View android:layout_width="30dp" android:layout_height="1dp" android:layout_marginTop="4dp" android:layout_marginBottom="4dp" android:background="#80FFFFFF" /><TextView android:id="@+id/tvDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15/05/2025" android:textColor="#E0FFFFFF" android:textSize="11sp" /></LinearLayout></androidx.cardview.widget.CardView>

                        <!-- Card 2: Thời tiết -->
                        <androidx.cardview.widget.CardView android:layout_width="130dp" android:layout_height="100dp" android:layout_marginEnd="10dp" app:cardCornerRadius="16dp" app:cardElevation="3dp" app:cardBackgroundColor="#FFFFFF"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="10dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌤 Thời tiết" android:textColor="#9E9E9E" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.05" /><LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="center_vertical" android:orientation="horizontal"><ImageView android:id="@+id/imgWeatherIcon" android:layout_width="32dp" android:layout_height="32dp" android:scaleType="fitCenter" /><LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="6dp"><TextView android:id="@+id/tvWeatherTemp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--°C" android:textColor="#1A1A2E" android:textSize="18sp" android:textStyle="bold" /><TextView android:id="@+id/tvWeatherDesc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="..." android:textColor="#9E9E9E" android:textSize="10sp" android:maxLines="1" android:ellipsize="end" /></LinearLayout></LinearLayout><TextView android:id="@+id/tvWeatherCity" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hà Nội" android:textColor="#1877F2" android:textSize="10sp" android:textStyle="bold" /></LinearLayout></androidx.cardview.widget.CardView>

                        <!-- Card 3: Giá xăng -->
                        <androidx.cardview.widget.CardView android:layout_width="120dp" android:layout_height="100dp" android:layout_marginEnd="10dp" app:cardCornerRadius="16dp" app:cardElevation="3dp" app:cardBackgroundColor="#FFFFFF"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="10dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Components" android:textColor="#9E9E9E" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.05" /><TextView android:id="@+id/tvPetrolPrice" android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:gravity="center_vertical" android:text="--,--- đ" android:textColor="#E65100" android:textSize="15sp" android:textStyle="bold" /><TextView android:id="@+id/tvPetrolType" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="E10 RON95" android:textColor="#9E9E9E" android:textSize="10sp" /></LinearLayout></androidx.cardview.widget.CardView>

                        <!-- Card 4: Giá vàng -->
                        <androidx.cardview.widget.CardView android:layout_width="130dp" android:layout_height="100dp" android:layout_marginEnd="4dp" app:cardCornerRadius="16dp" app:cardElevation="3dp" app:cardBackgroundColor="#FFFFFF"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="10dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🥇 Giá vàng SJC" android:textColor="#9E9E9E" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.05" /><LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="center_vertical" android:orientation="vertical"><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mua " android:textColor="#9E9E9E" android:textSize="10sp" /><TextView android:id="@+id/tvGoldBuy" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="#2E7D32" android:textSize="13sp" android:textStyle="bold" /></LinearLayout><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:orientation="horizontal" android:gravity="center_vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bán " android:textColor="#9E9E9E" android:textSize="10sp" /><TextView android:id="@+id/tvGoldSell" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="#C62828" android:textSize="13sp" android:textStyle="bold" /></LinearLayout></LinearLayout><TextView android:id="@+id/tvGoldUnit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="triệu đ/lượng" android:textColor="#9E9E9E" android:textSize="10sp" /></LinearLayout></androidx.cardview.widget.CardView>

                    </LinearLayout>
                </HorizontalScrollView>

                <ProgressBar
                    android:id="@+id/homeProgressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:indeterminateTint="#1877F2"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/homeTvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:gravity="center"
                    android:padding="24dp"
                    android:textColor="#9E9E9E"
                    android:textSize="15sp"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.appbar.AppBarLayout>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- Danh sách bài viết được giải phóng hoàn toàn sức mạnh            -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- ĐỂ LÀM VIEW CHÍNH CUỘN TRÊN MÀN HÌNH: Sẽ tự động tái sử dụng Holder -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/homeRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="16dp"
            android:paddingTop="8dp"
            android:clipToPadding="false"
            app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>