<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚙ Tiện ích"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp" />

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- Card cỡ chữ — Slider kéo theo %  (GIỮ NGUYÊN 100% không đổi)        -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardFontSize"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Tiêu đề + % hiện tại -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔤 Cỡ chữ bài viết"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <!-- Badge hiển thị % đang chọn -->
                <TextView
                    android:id="@+id/tvFontPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#060810"
                    android:background="@drawable/bg_category_badge"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="3dp" />

            </LinearLayout>

            <!-- Preview chữ -->
            <TextView
                android:id="@+id/tvFontPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"
                android:text="Đây là cỡ chữ mẫu khi đọc bài viết"
                android:textColor="?attr/colorOnSurface"
                android:gravity="center"
                android:maxLines="2" />

            <!-- Slider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderFontSize"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:valueFrom="80"
                    android:valueTo="150"
                    android:stepSize="10"
                    android:value="100"
                    app:thumbColor="#1877F2"
                    app:trackColorActive="#1877F2"
                    app:trackColorInactive="#D0D9F5"
                    app:haloColor="#331877F2"
                    app:labelBehavior="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="80%"
                    android:textSize="10sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="start" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textSize="10sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="center" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="150%"
                    android:textSize="10sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="end" />

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- Tab "Đã lưu" / "Lịch sử" — thay cho header tĩnh cũ                  -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabSavedHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabIndicatorColor="#1877F2"
        app:tabSelectedTextColor="#1877F2"
        app:tabTextColor="?attr/colorOnSurfaceVariant"
        app:tabIndicatorHeight="3dp"
        android:background="@drawable/bg_search">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❤ Đã lưu" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🕘 Lịch sử" />

    </com.google.android.material.tabs.TabLayout>

    <!-- Nút xóa toàn bộ lịch sử — chỉ hiện khi đang ở tab Lịch sử -->
    <TextView
        android:id="@+id/btnClearHistory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="4dp"
        android:text="Xóa tất cả"
        android:textSize="13sp"
        android:textColor="#E53935"
        android:padding="6dp"
        android:visibility="gone"
        android:background="?attr/selectableItemBackground" />

    <!-- Card yêu cầu đăng nhập — chỉ áp dụng cho tab "Đã lưu" -->
    <androidx.cardview.widget.CardView
        android:id="@+id/layoutLoginPrompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔐"
                android:textSize="48sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đăng nhập để lưu bài viết"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lưu các bài viết yêu thích và đọc lại bất cứ lúc nào, kể cả khi offline."
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btnGoLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đăng nhập ngay"
                android:layout_marginTop="20dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- Vùng nội dung dùng chung — đổi adapter theo tab đang chọn            -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/savedRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="80dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/savedTvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:padding="32dp"
            android:textSize="15sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>